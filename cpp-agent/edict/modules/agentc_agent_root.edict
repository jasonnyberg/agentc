# agentc_agent_root.edict — first canonical Edict agent-root shape
#
# Prerequisite: load `cpp-agent/edict/modules/agentc.edict`,
# `cpp-agent/edict/modules/agentc_stateful_loop.edict`, and
# `cpp-agent/edict/modules/agentc_provider_contracts.edict` first.
#
# Defined wrappers:
#   agentc_agent_root_init!              ( system_prompt -- root )
#   agentc_agent_root_init_with_runtime! ( system_prompt runtime_config -- root )
#   agentc_agent_root_create_runtime!    ( root -- runtime_handle )
#   agentc_agent_root_text!              ( root -- assistant_text )
#   agentc_agent_root_messages!          ( root -- messages )
#   agentc_agent_root_stage_user_turn!   ( root prompt -- root )
#   agentc_agent_root_build_turn_request! ( root -- request )
#   agentc_agent_root_apply_turn_response!( root response -- root )
#   agentc_agent_root_turn!              ( runtime_handle root prompt -- root )
#   agentc_agent_root_demo!              ( config_path system_prompt prompt -- root )
#
# Root shape:
# - `conversation` : conversation-bearing Edict state from agentc_stateful_loop.edict
# - `memory`       : durable Edict-owned memory namespace (empty for now)
# - `policy`       : policy/config placeholders owned by Edict
# - `runtime`      : declarative runtime config metadata
# - `loop`         : lightweight loop metadata
#
# This is the first step from transcript persistence toward a canonical VM/root state.

[
    @runtime_config @system_prompt
    agentc_state_init(system_prompt) @conversation
    {"conversation": null, "memory": null, "policy": null, "runtime": null, "loop": null} @root
    conversation @root.conversation
    {"entries": []} @memory
    memory @root.memory
    {"allow_tools": "false"} @policy
    policy @root.policy
    runtime_config @root.runtime
    {"status": "ready", "last_prompt": null} @loop
    loop @root.loop
    root
] @agentc_agent_root_init_with_runtime

[
    @system_prompt
    agentc_provider_default_runtime_config! @runtime_config
    agentc_agent_root_init_with_runtime(system_prompt runtime_config)
] @agentc_agent_root_init

[
    @root
    agentc_runtime_create(root.runtime)
] @agentc_agent_root_create_runtime

[ @root root.conversation.assistant_text ] @agentc_agent_root_text
[ @root root.conversation.messages ] @agentc_agent_root_messages

[
    @prompt @root
    agentc_state_push_user(root.conversation prompt) @root.conversation
    prompt @root.loop.last_prompt
    "awaiting-provider" @root.loop.status
    root
] @agentc_agent_root_stage_user_turn

[
    @root
    root.runtime.provider_contract @provider_spec
    agentc_provider_build_turn_request(provider_spec root.runtime root.conversation)
] @agentc_agent_root_build_turn_request

[
    @response @root
    root.conversation response agentc_state_apply_response! @conversation
    conversation @root.conversation
    "turn-complete" @root.loop.status
    root
] @agentc_agent_root_apply_turn_response

[
    @prompt @root @runtime_handle
    agentc_agent_root_stage_user_turn(root prompt) @next_root
    next_root agentc_agent_root_build_turn_request! @request
    agentc_call(runtime_handle request) @response
    next_root response agentc_agent_root_apply_turn_response!
] @agentc_agent_root_turn

[
    @prompt @system_prompt @config_path
    agentc_read_json_file(config_path) @runtime_config
    agentc_agent_root_init_with_runtime(system_prompt runtime_config) @root
    agentc_agent_root_create_runtime(root) @runtime
    agentc_agent_root_turn(runtime root prompt) @next_root
    agentc_destroy(runtime) /
    next_root
] @agentc_agent_root_demo
