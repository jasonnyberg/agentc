# agentc_curated.edict — curated loader/bootstrap helpers for AgentC Edict sessions
#
# Expected launcher contract:
# - inject a global `EDICT_PATH` object with concrete filesystem paths
# - load this module
# - call `agentc_curated_init! /`
#
# Public surface:
# - `edict_eval_file!`                ( path -- )
# - `agentc_bootstrap_from_path!`     ( edict_path -- bootstrap )
# - `agentc_load_curated_modules!`    ( edict_path -- [ok] )
# - `agentc_configure_curated_llm!`   ( edict_path -- bootstrap )
# - `agentc_curated_init!`            ( -- [ok] )

"" @agentc_curated_modules_loaded

[
    @path
    path resolver.__native.read_text!!
] @edict_eval_file

[
    @edict_path
    {"extensions_library_path": "", "extensions_header_path": "", "runtime_library_path": "", "runtime_header_path": ""} @bootstrap
    edict_path.extensions_library_path @bootstrap.extensions_library_path
    edict_path.extensions_header_path @bootstrap.extensions_header_path
    edict_path.runtime_library_path @bootstrap.runtime_library_path
    edict_path.runtime_header_path @bootstrap.runtime_header_path
    bootstrap
] @agentc_bootstrap_from_path

[
    @edict_path
    agentc_curated_modules_loaded test &
        [ok]
    |
        edict_path.modules.agentc edict_eval_file!
        edict_path.modules.stateful_loop edict_eval_file!
        edict_path.modules.provider_contracts edict_eval_file!
        edict_path.modules.agent_root edict_eval_file!
        edict_path.modules.llm edict_eval_file!
        [true] @agentc_curated_modules_loaded
        [ok]
] @agentc_load_curated_modules

[
    @edict_path
    edict_path agentc_bootstrap_from_path! @bootstrap
    bootstrap llm.configure_bootstrap! /
    bootstrap
] @agentc_configure_curated_llm

[
    EDICT_PATH @edict_path
    edict_path agentc_load_curated_modules! /
    edict_path agentc_configure_curated_llm! /
    [ok]
] @agentc_curated_init
