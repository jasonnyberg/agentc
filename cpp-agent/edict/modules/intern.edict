# intern.edict — G111 public intern surface over worker primitives
#
# Prerequisite: worker.edict has installed the `worker` namespace.
#
# This transitional module preserves the current public intern surface while
# moving the words themselves out of VM opcode registration. Task preparation,
# start-time capacity/backpressure branching, public backpressure envelopes,
# and async sync/cancel public envelopes now live in this Edict layer; native
# worker primitives still own the irreducible worker table, thread, and fresh
# VM mechanics until later G111/G091 slices split those further.

{} @intern

[
    @capacity @spec
    {"ok": [], "state": "backpressure", "worker": "edict-thread-async", "events": []} @envelope
    spec.task_id @envelope.task_id
    {} @envelope.job_id
    {} @envelope.waitable
    {} @envelope.publication
    {} @error
    'backpressure @error.code
    capacity.message @error.message
    error @envelope.error
    {} @event
    'backpressure @event.kind
    '0 @event.sequence
    '0 @event.correlation_id
    '0 @event.grant_token
    capacity.message @event.payload
    event ^envelope.events^ /
    envelope
] @intern.backpressure_envelope

[
    @status
    {"ok": ["ok"], "state": "running", "worker": "edict-thread-async", "complete": []} @envelope
    status.job_id @envelope.job_id
    status.task_id @envelope.task_id
    status.waitable @envelope.waitable
    status.events @envelope.events
    status.publication @envelope.publication
    envelope
] @intern.running_envelope

[
    @status
    {"ok": ["ok"], "state": "cancel_requested", "worker": "edict-thread-async", "complete": []} @envelope
    status.job_id @envelope.job_id
    status.task_id @envelope.task_id
    status.waitable @envelope.waitable
    status.events @envelope.events
    status.publication @envelope.publication
    envelope
] @intern.cancel_requested_envelope

[
    @status
    {"ok": ["ok"], "state": "complete", "worker": "edict-thread-async"} @envelope
    status.job_id @envelope.job_id
    status.task_id @envelope.task_id
    status.waitable @envelope.waitable
    status.result @envelope.result
    status.safety @envelope.safety
    status.publication @envelope.publication
    status.events @envelope.events
    {} @envelope.error
    envelope
] @intern.complete_envelope

[
    @status
    {"ok": [], "state": "error", "worker": "edict-thread-async"} @envelope
    status.job_id @envelope.job_id
    status.task_id @envelope.task_id
    status.waitable @envelope.waitable
    status.result @envelope.result
    status.safety @envelope.safety
    status.publication @envelope.publication
    {} @error
    status.error_code @error.code
    status.error_message @error.message
    error @envelope.error
    status.events @envelope.events
    envelope
] @intern.error_envelope

[
    @status
    {"ok": [], "state": "cancelled", "worker": "edict-thread-async"} @envelope
    status.job_id @envelope.job_id
    status.task_id @envelope.task_id
    status.waitable @envelope.waitable
    status.result @envelope.result
    status.safety @envelope.safety
    status.publication @envelope.publication
    {} @error
    'cancelled @error.code
    status.error_message @error.message
    error @envelope.error
    status.default_events @envelope.events
    envelope
] @intern.cancelled_envelope

[
    @status
    {"ok": [], "state": "error", "worker": "edict-thread-async"} @envelope
    status.job_id @envelope.job_id
    status.task_id @envelope.task_id
    status.waitable @envelope.waitable
    status.result @envelope.result
    status.safety @envelope.safety
    status.publication @envelope.publication
    {} @error
    'unknown_job @error.code
    status.error_message @error.message
    error @envelope.error
    status.events @envelope.events
    envelope
] @intern.unknown_job_envelope

[
    @status
    status.terminal test & status.cancelled test &
        {"ok": [], "state": "cancelled", "worker": "edict-thread-async"} @envelope
        status.job_id @envelope.job_id
        status.task_id @envelope.task_id
        status.waitable @envelope.waitable
        status.result @envelope.result
        status.safety @envelope.safety
        status.publication @envelope.publication
        {} @error
        'cancelled @error.code
        status.error_message @error.message
        error @envelope.error
        status.events @envelope.events
        envelope
    | status.worker_ok test &
        {"ok": ["ok"], "state": "complete", "worker": "edict-thread-async"} @envelope
        status.job_id @envelope.job_id
        status.task_id @envelope.task_id
        status.waitable @envelope.waitable
        status.result @envelope.result
        status.safety @envelope.safety
        status.publication @envelope.publication
        status.events @envelope.events
        {} @envelope.error
        envelope
    |
        {"ok": [], "state": "error", "worker": "edict-thread-async"} @envelope
        status.job_id @envelope.job_id
        status.task_id @envelope.task_id
        status.waitable @envelope.waitable
        status.result @envelope.result
        status.safety @envelope.safety
        status.publication @envelope.publication
        {} @error
        status.error_code @error.code
        status.error_message @error.message
        error @envelope.error
        status.events @envelope.events
        envelope
    | status.cancel_requested test &
        {"ok": ["ok"], "state": "cancel_requested", "worker": "edict-thread-async", "complete": []} @envelope
        status.job_id @envelope.job_id
        status.task_id @envelope.task_id
        status.waitable @envelope.waitable
        status.events @envelope.events
        status.publication @envelope.publication
        envelope
    |
        {"ok": ["ok"], "state": "running", "worker": "edict-thread-async", "complete": []} @envelope
        status.job_id @envelope.job_id
        status.task_id @envelope.task_id
        status.waitable @envelope.waitable
        status.events @envelope.events
        status.publication @envelope.publication
        envelope
] @intern.sync_envelope

[
    @status
    status.worker_ok test &
        {"ok": ["ok"], "state": "complete", "worker": "edict-thread"} @envelope
        status.task_id @envelope.task_id
        status.result @envelope.result
        status.safety @envelope.safety
        status.publication @envelope.publication
        {} @envelope.error
        envelope
    |
        {"ok": [], "state": "error", "worker": "edict-thread"} @envelope
        status.task_id @envelope.task_id
        status.result @envelope.result
        status.safety @envelope.safety
        status.publication @envelope.publication
        {} @error
        status.error_code @error.code
        status.error_message @error.message
        error @envelope.error
        envelope
] @intern.run_envelope

[
    @status
    {"ok": ["ok"], "state": "started", "worker": "edict-thread-async"} @envelope
    status.job_id @envelope.job_id
    status.task_id @envelope.task_id
    status.waitable @envelope.waitable
    status.publication @envelope.publication
    envelope
] @intern.started_envelope

[
    @status
    {"ok": [], "state": "backpressure", "worker": "edict-thread-async"} @envelope
    status.task_id @envelope.task_id
    status.job_id @envelope.job_id
    status.waitable @envelope.waitable
    status.publication @envelope.publication
    {} @error
    status.error_code @error.code
    status.error_message @error.message
    error @envelope.error
    status.events @envelope.events
    envelope
] @intern.start_backpressure_envelope

[
    @status
    status.started test &
        {"ok": ["ok"], "state": "started", "worker": "edict-thread-async"} @envelope
        status.job_id @envelope.job_id
        status.task_id @envelope.task_id
        status.waitable @envelope.waitable
        status.publication @envelope.publication
        envelope
    |
        {"ok": [], "state": "error", "worker": "edict-thread-async"} @envelope
        status.state @envelope.state
        status.task_id @envelope.task_id
        status.job_id @envelope.job_id
        status.waitable @envelope.waitable
        status.publication @envelope.publication
        {} @error
        status.error_code @error.code
        status.error_message @error.message
        error @envelope.error
        status.events @envelope.events
        envelope
] @intern.start_envelope

[
    @task
    task.program test &
        task.expect.success_field test &
            task.limits.max_result_bytes test &
                {"ok": ["ok"], "state": "contract_valid", "kind": "intern_task_contract"} @status
                task.task_id @status.task_id
                task.limits @status.limits
                task.expect @status.expect
                {} @status.error
                status
            |
                {"ok": [], "state": "contract_error", "kind": "intern_task_contract"} @status
                task.task_id @status.task_id
                {} @error
                'missing_result_limit @error.code
                'intern task contract requires limits.max_result_bytes @error.message
                error @status.error
                status
        |
            {"ok": [], "state": "contract_error", "kind": "intern_task_contract"} @status
            task.task_id @status.task_id
            {} @error
            'missing_success_field @error.code
            'intern task contract requires expect.success_field @error.message
            error @status.error
            status
    |
        {"ok": [], "state": "contract_error", "kind": "intern_task_contract"} @status
        task.task_id @status.task_id
        {} @error
        'missing_program @error.code
        'intern task contract requires a non-empty program @error.message
        error @status.error
        status
] @intern.validate_task_contract

[
    @contract
    {"ok": [], "state": "error", "worker": "edict-thread-async"} @envelope
    contract.task_id @envelope.task_id
    {} @envelope.job_id
    {} @envelope.waitable
    {} @envelope.publication
    contract.error @envelope.error
    {} @envelope.events
    envelope
] @intern.contract_error_envelope

[
    @envelope
    envelope.state test &
        {"ok": ["ok"], "state": "envelope_valid", "kind": "intern_status_envelope"} @status
        envelope.state @status.envelope_state
        envelope.job_id @status.job_id
        envelope.task_id @status.task_id
        envelope.publication @status.publication
        {} @status.error
        status
    |
        {"ok": [], "state": "contract_error", "kind": "intern_status_envelope"} @status
        envelope.task_id @status.task_id
        {} @error
        'missing_state @error.code
        'intern status envelope requires state @error.message
        error @status.error
        status
] @intern.validate_status_envelope

[
    {"task_class": "gather", "task_id": "example-gather", "program": "'ok @result.ok 'gather @result.task_class 'bounded facts with file/path evidence @result.summary ['evidence://file:line'] @result.evidence 'high @result.confidence"} @task
    {"max_result_bytes": "65536", "timeout_ms": "1000", "max_events": "100"} @task.limits
