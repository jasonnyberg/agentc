    {"max_result_bytes": "32768", "timeout_ms": "1000", "max_events": "100"} @task.limits
    {"result_shape": "object", "success_field": "ok", "evidence_field": "evidence", "min_evidence_count": "1", "min_confidence": "medium"} @task.expect
