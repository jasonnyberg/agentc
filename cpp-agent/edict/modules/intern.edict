# intern.edict — G111 public intern surface over worker primitives
#
# Prerequisite: worker.edict has installed the `worker` namespace.
#
# This transitional module preserves the current public intern surface while
# moving the words themselves out of VM opcode registration. Task preparation
# and start-time capacity/backpressure branching now live in this Edict layer;
# this slice also moves the public backpressure envelope into Edict. Native
# worker primitives still shape most running/final envelopes until later G111
# slices move that policy down into Edict too.

{} @intern

[
    @capacity @spec
    {"ok": [], "state": "backpressure", "worker": "edict-thread-async", "events": []} @envelope
    spec.task_id @envelope.task_id
    {} @envelope.job_id
    {} @envelope.waitable
    {} @envelope.publication
    {} @error
    'backpressure @error.code
    capacity.message @error.message
    error @envelope.error
    {} @event
    'backpressure @event.kind
    '0 @event.sequence
    '0 @event.correlation_id
    '0 @event.grant_token
    capacity.message @event.payload
    event ^envelope.events^ /
    envelope
] @intern.backpressure_envelope

[@task task worker.edict_prepare_task! @spec spec.ok test & spec worker.edict_run_prepared! | spec] @intern_run
[@task task worker.edict_prepare_task! @spec spec.ok test & spec worker.edict_capacity_status! @capacity capacity.ok test & capacity.allowed test & spec worker.edict_start_prepared! | spec capacity intern.backpressure_envelope! | capacity | spec] @intern_start
[@job job worker.edict_drain_events! @events job events worker.edict_collect!] @intern_sync
[@job job worker.edict_request_cancel! @events job events worker.edict_collect!] @intern_cancel
