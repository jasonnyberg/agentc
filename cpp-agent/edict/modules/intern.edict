[worker.edict_validate_result_contract!] @intern.validate_result_contract
[
    @envelope @expect
    {} @check
    expect @check.expect
    envelope @check.envelope
    check intern.validate_result_contract!
] @intern.validate_trusted_result

[@task task worker.edict_prepare_task! @spec spec.ok test & spec worker.edict_run_status_prepared! @status status intern.run_envelope! | spec] @intern_run
[@task task worker.edict_start_status! @status status intern.start_envelope!] @intern_start
[@job job worker.edict_drain_events! @events job events worker.edict_collect_status! @status status intern.sync_envelope!] @intern_sync
[@job job worker.edict_request_cancel! @events job events worker.edict_collect_status! @status status intern.sync_envelope!] @intern_cancel
