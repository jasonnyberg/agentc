# worker.edict — G111 low-level Edict-worker primitive wrappers
#
# Prerequisite:
#   [<libedict.so>] [<agentc_worker_primitives.h>] resolver.import! @workerffi
#
# These are substrate words, not the normal user-facing intern API.  They wrap
# imported native primitives that currently start/collect local Edict worker
# jobs.  intern.edict layers the public intern words over this namespace.

{} @worker
[workerffi.agentc_worker_edict_active_count_ltv!] @worker.edict_active_count
[workerffi.agentc_worker_edict_prepare_task_ltv!] @worker.edict_prepare_task
[workerffi.agentc_worker_edict_capacity_status_ltv!] @worker.edict_capacity_status
[workerffi.agentc_worker_edict_run_status_ltv!] @worker.edict_run_status
[workerffi.agentc_worker_edict_run_status_prepared_ltv!] @worker.edict_run_status_prepared
[workerffi.agentc_worker_edict_start_status_ltv!] @worker.edict_start_status
[workerffi.agentc_worker_edict_start_status_prepared_ltv!] @worker.edict_start_status_prepared
[workerffi.agentc_worker_edict_drain_events_ltv!] @worker.edict_drain_events
[workerffi.agentc_worker_edict_request_cancel_ltv!] @worker.edict_request_cancel
[workerffi.agentc_worker_edict_collect_status_ltv!] @worker.edict_collect_status
[workerffi.agentc_worker_edict_validate_result_contract_ltv!] @worker.edict_validate_result_contract
[workerffi.agentc_worker_edict_drop_ltv!] @worker.edict_drop
